# -----------------------------------------------------------------------------
# Python bytecode and interpreter caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# Native extensions
*.so
*.pyd
*.dll

# -----------------------------------------------------------------------------
# Conda and virtual environments
# -----------------------------------------------------------------------------
.conda/
conda-meta/
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Packaging and build output
# -----------------------------------------------------------------------------
build/
dist/
downloads/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Test, coverage, type-checking and linter caches
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.mypy_cache/
.pyright/
.ruff_cache/

# -----------------------------------------------------------------------------
# Environment variables, credentials and local secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/

# -----------------------------------------------------------------------------
# Application runtime data
# -----------------------------------------------------------------------------
*.log
logs/
uploads/
exports/
var/
.local/
*.db
*.sqlite
*.sqlite3

# Keep version-controlled fixtures and evaluation datasets outside these paths,
# for example under tests/fixtures/ or evals/.

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# IDE and editor settings
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Operating system files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Local Docker overrides
# -----------------------------------------------------------------------------
compose.override.yaml
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
